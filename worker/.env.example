# === Supabase ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_MANAGER_MODEL=claude-haiku-4-5-20251001

# === Loop tuning ===
HEARTBEAT_INTERVAL_MS=30000
AGENT_TICK_INTERVAL_MS=60000

# === Demo mode ===
# Set to true to skip real Anthropic calls and generate plausible fake activity.
# Useful for sales demos and when you don't want to burn API credits.
DEMO_MODE=true

# === LLM provider ===
# anthropic (default — needs balance at console.anthropic.com)
# openrouter (sign up at openrouter.ai, $5 credit goes far, use Claude or any model)
# gemini (free tier — get key at aistudio.google.com)
LLM_PROVIDER=anthropic
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# === MCP server overrides (used when agent.mcp_tools doesn't include server_url) ===
# Look up endpoint at developer.hubspot.com or use your private MCP server URL
HUBSPOT_MCP_URL=https://mcp.hubspot.com/anthropic
GMAIL_MCP_URL=
SLACK_MCP_URL=
